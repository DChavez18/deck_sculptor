<div class="max-w-2xl">
  <div class="flex gap-6">
    <% if @commander.image_url.present? %>
      <img src="<%= @commander.image_url %>" alt="<%= @commander.name %>" class="w-48 rounded-xl">
    <% end %>
    <div>
      <h1 class="text-3xl font-bold text-white"><%= @commander.name %></h1>
      <p class="text-slate-400 text-sm mt-1"><%= @commander.type_line %></p>
      <p class="text-slate-500 font-mono text-sm mt-1"><%= @commander.mana_cost %></p>

      <% unless @commander.color_names.empty? %>
        <div class="flex flex-wrap gap-2 mt-3">
          <% @commander.color_names.each do |color| %>
            <span class="text-sm bg-slate-700 text-slate-300 px-3 py-1 rounded-full"><%= color %></span>
          <% end %>
        </div>
      <% end %>

      <p class="text-slate-300 text-sm mt-4 leading-relaxed"><%= @commander.oracle_text %></p>

      <div class="mt-6">
        <%= link_to "Build a Deck with #{@commander.name}", new_deck_path,
            class: "bg-blue-600 hover:bg-blue-500 text-white px-5 py-2 rounded-md font-medium text-sm" %>
      </div>
    </div>
  </div>
</div>
