<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Deck Sculptor" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-slate-900 text-slate-100 min-h-screen">
    <nav class="bg-slate-800 border-b border-slate-700 px-4 py-3 sm:px-6 sm:py-4">
      <div class="max-w-6xl mx-auto flex flex-wrap items-center justify-between gap-2">
        <%= link_to "Deck Sculptor", root_path, class: "text-blue-400 font-bold text-xl tracking-wide hover:text-blue-300" %>
        <div class="flex flex-wrap gap-2 sm:gap-4 items-center">
          <%= link_to "My Decks",   decks_path,     class: "text-slate-300 hover:text-white text-sm" %>
          <%= link_to "Templates",  templates_path, class: "text-slate-300 hover:text-white text-sm" %>
          <%= link_to "New Deck",   new_deck_path,  class: "bg-blue-600 hover:bg-blue-500 text-white text-sm px-4 py-2 rounded-md font-medium" %>
        </div>
      </div>
    </nav>

    <% if notice %>
      <div class="max-w-6xl mx-auto mt-4 px-6">
        <div class="bg-blue-900 border border-blue-700 text-blue-200 px-4 py-3 rounded-md text-sm">
          <%= notice %>
        </div>
      </div>
    <% end %>

    <% if alert %>
      <div class="max-w-6xl mx-auto mt-4 px-6">
        <div class="bg-red-900 border border-red-700 text-red-200 px-4 py-3 rounded-md text-sm">
          <%= alert %>
        </div>
      </div>
    <% end %>

    <main class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
      <%= yield %>
    </main>
  </body>
</html>
