<div id="chat-input" data-ai-chat-target="inputWrapper">
  <%= form_with url: deck_deck_chats_path(deck), method: :post,
      data: { action: "submit->ai-chat#send", turbo_stream: true } do |f| %>
    <div class="flex gap-2 items-end">
      <textarea name="message"
                rows="2"
                placeholder="Ask about your deck..."
                data-ai-chat-target="textarea"
                class="flex-1 bg-slate-700 border border-slate-600 text-white placeholder-slate-400 rounded-lg px-3 py-2 text-sm resize-none focus:outline-none focus:border-blue-500"></textarea>
      <button type="submit"
              data-ai-chat-target="sendButton"
              class="bg-blue-600 hover:bg-blue-500 text-white text-sm px-4 py-2 rounded-lg font-medium shrink-0 disabled:opacity-50 disabled:cursor-not-allowed">
        Send
      </button>
    </div>
  <% end %>
</div>
