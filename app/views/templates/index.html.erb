<div class="mb-8">
  <h1 class="text-3xl font-bold text-white">Deck Templates</h1>
  <p class="text-slate-400 mt-2">Choose a starter archetype to build your Commander deck around.</p>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
  <% @templates.each do |template| %>
    <div class="bg-slate-800 border border-slate-700 rounded-xl p-5 flex flex-col hover:border-slate-500 transition-colors">
      <div class="mb-3">
        <span class="text-xs font-medium text-blue-400 uppercase tracking-wide"><%= template[:color_identity] %></span>
        <h2 class="text-white font-bold text-xl mt-1"><%= template[:name] %></h2>
      </div>

      <p class="text-slate-400 text-sm leading-relaxed flex-1 mb-4"><%= template[:description] %></p>

      <div class="flex flex-wrap gap-1.5 mb-4">
        <span class="bg-slate-700 text-slate-300 text-xs px-2 py-0.5 rounded-full capitalize"><%= template[:archetype] %></span>
        <span class="bg-slate-700 text-slate-300 text-xs px-2 py-0.5 rounded-full">Bracket <%= template[:bracket_level] %></span>
        <span class="bg-slate-700 text-slate-300 text-xs px-2 py-0.5 rounded-full capitalize"><%= template[:win_condition] %></span>
      </div>

      <%= link_to template_path(template[:id]),
          class: "block w-full text-center bg-slate-700 hover:bg-slate-600 text-white text-sm font-medium py-2 rounded-md transition-colors" do %>
        View Template →
      <% end %>
    </div>
  <% end %>
</div>
