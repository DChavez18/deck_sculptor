<div class="mb-6 flex items-center gap-4">
  <%= link_to "← Back to Deck", deck_path(@deck), class: "text-slate-400 hover:text-white text-sm" %>
  <h1 class="text-2xl font-bold text-white">Analysis: <%= @deck.name %></h1>
</div>

<%# Strategy analysis section %>
<div class="mb-6 bg-slate-800 border border-slate-700 rounded-xl p-5">
  <h2 class="text-white font-semibold mb-4">Strategy Analysis</h2>

  <div class="flex flex-wrap items-start gap-4 mb-4">
    <%# Detected archetype badge %>
    <% if @strategy[:detected_archetype] %>
      <div>
        <p class="text-slate-400 text-xs mb-1">Detected Archetype</p>
        <% same_as_selected = @strategy[:detected_archetype] == @deck.archetype %>
        <span class="inline-block px-3 py-1 rounded-full text-sm font-semibold capitalize
          <%= same_as_selected ? 'bg-blue-600 text-white' : 'bg-amber-500 text-slate-900' %>">
          <%= @strategy[:detected_archetype] %>
        </span>
        <% unless same_as_selected || @deck.archetype.blank? %>
          <p class="text-amber-400 text-xs mt-1">Differs from selected: <%= @deck.archetype %></p>
        <% end %>
      </div>
    <% else %>
      <p class="text-slate-400 text-sm">Add at least 10 cards to detect archetype.</p>
    <% end %>

    <%# Key themes %>
    <% if @strategy[:key_themes].any? %>
      <div>
        <p class="text-slate-400 text-xs mb-1">Key Themes</p>
        <div class="flex flex-wrap gap-1.5">
          <% @strategy[:key_themes].each do |theme| %>
            <span class="bg-slate-700 text-slate-200 text-xs px-2 py-0.5 rounded-full capitalize"><%= theme %></span>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <%# Strategy summary %>
  <p class="text-slate-300 text-sm leading-relaxed"><%= @strategy[:strategy_summary] %></p>

  <%# Color gap warnings %>
  <% gaps = @strategy[:color_gaps] %>
  <% if gaps[:missing_colors].any? %>
    <div class="mt-4 border border-amber-500/30 bg-amber-500/10 rounded-lg p-3">
      <p class="text-amber-400 text-sm font-medium mb-1">⚠ Color Gaps Detected</p>
      <p class="text-slate-300 text-xs">
        The following colors from your commander's identity have no representation in the 99:
        <span class="font-semibold text-amber-300">
          <%= gaps[:missing_colors].map { |c| Commander::COLOR_MAP[c] || c }.join(", ") %>
        </span>
      </p>
    </div>
  <% end %>

  <% if gaps[:off_color_cards].any? %>
    <div class="mt-3 border border-red-500/30 bg-red-500/10 rounded-lg p-3">
      <p class="text-red-400 text-sm font-medium mb-1">⚠ Off-Color Cards</p>
      <p class="text-slate-300 text-xs">
        <%= gaps[:off_color_cards].map(&:card_name).join(", ") %>
      </p>
    </div>
  <% end %>
</div>

<%# Card type ratio targets %>
<div class="mb-6 bg-slate-800 border border-slate-700 rounded-xl p-5">
  <h2 class="text-white font-semibold mb-4">Card Type Ratios</h2>
  <% if @ratio_report.values.all? { |r| r[:actual] == 0 } %>
    <p class="text-slate-400 text-sm">No cards yet.</p>
  <% else %>
    <div class="space-y-3">
      <% @ratio_report.each do |bucket, data| %>
        <% actual = data[:actual]; target = data[:target] %>
        <% pct = [ (actual.to_f / target * 100).round, 100 ].min %>
        <% diff = actual - target %>
        <% bar_color = diff >= 0 ? "bg-green-500" : (diff >= -3 ? "bg-amber-500" : "bg-red-500") %>
        <div>
          <div class="flex items-center justify-between mb-1">
            <span class="text-slate-300 text-xs capitalize font-medium"><%= bucket %></span>
            <span class="text-slate-400 text-xs"><%= actual %> / <%= target %>
              <% if diff > 0 %>
                <span class="text-green-400 ml-1">+<%= diff %></span>
              <% elsif diff < 0 %>
                <span class="text-red-400 ml-1"><%= diff %></span>
              <% end %>
            </span>
          </div>
          <div class="bg-slate-700 rounded-full h-3 overflow-hidden">
            <div class="<%= bar_color %> h-3 rounded-full transition-all" style="width: <%= pct %>%"></div>
          </div>
          <%# Cut suggestions %>
          <% if data[:cut_suggestions].any? %>
            <div class="mt-1.5 text-xs text-slate-400">
              Consider cutting:
              <% data[:cut_suggestions].each_with_index do |cut, i| %>
                <span class="text-slate-300"><%= cut[:name] %> (CMC <%= cut[:cmc] %>)<%= i < data[:cut_suggestions].size - 1 ? "," : "" %></span>
              <% end %>
              <span class="text-slate-500 ml-1">— you have <%= actual %>, target is <%= target %></span>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>

<%# Near-miss combos %>
<% if @near_miss_combos.any? %>
  <div class="mt-6 bg-slate-800 border border-slate-700 rounded-xl p-5">
    <h2 class="text-white font-semibold mb-1">One Card Away</h2>
    <p class="text-slate-400 text-sm mb-4">These combos are almost complete — add the missing card to unlock them.</p>
    <div class="space-y-4">
      <% @near_miss_combos.each do |nm| %>
        <div class="border border-amber-700/40 bg-amber-500/5 rounded-lg p-4">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1 min-w-0">
              <%# Combo cards with presence indicator %>
              <div class="flex flex-wrap gap-1.5 mb-2">
                <% nm[:combo][:cards].each do |card_name| %>
                  <% in_deck = @deck.deck_cards.any? { |dc| dc.card_name.casecmp?(card_name) } || @deck.commander.name.casecmp?(card_name) %>
                  <span class="text-xs px-2 py-0.5 rounded-full font-medium <%= in_deck ? 'bg-slate-600 text-slate-300' : 'bg-amber-700/60 text-amber-200' %>">
                    <%= card_name %><%= " ✓" if in_deck %>
                  </span>
                <% end %>
              </div>

              <% if nm[:combo][:result].present? %>
                <p class="text-green-400 text-sm font-medium mb-1">⚡ <%= nm[:combo][:result] %></p>
              <% end %>

              <p class="text-amber-400 text-xs font-medium mt-1">
                Missing: <span class="text-amber-200"><%= nm[:missing_card] %></span>
              </p>

              <% if nm[:combo][:steps].present? %>
                <p class="text-slate-400 text-xs leading-relaxed mt-1 line-clamp-2"><%= nm[:combo][:steps] %></p>
              <% end %>
            </div>

            <%# Add the missing card %>
            <%= form_with url: deck_deck_cards_path(@deck), method: :post, class: "shrink-0" do |f| %>
              <%= f.hidden_field :card_name, value: nm[:missing_card] %>
              <%= f.submit "Add to Deck", name: nil,
                  class: "bg-amber-700 hover:bg-amber-600 text-white text-xs font-medium px-3 py-1.5 rounded-md cursor-pointer transition-colors whitespace-nowrap" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
<%# Mana curve advice %>
<% if @curve_advice.any? %>
  <div class="mb-6 bg-slate-800 border border-slate-700 rounded-xl p-5">
    <h2 class="text-white font-semibold mb-3">Mana Curve Recommendations</h2>
    <ul class="space-y-2">
      <% @curve_advice.each do |rec| %>
        <li class="flex items-start gap-2 text-sm text-slate-300">
          <span class="text-amber-400 mt-0.5 shrink-0">•</span>
          <%= rec %>
        </li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <%# Mana curve %>
  <div class="bg-slate-800 border border-slate-700 rounded-xl p-5">
    <h2 class="text-white font-semibold mb-4">Mana Curve</h2>
    <% if @mana_curve.empty? %>
      <p class="text-slate-400 text-sm">No non-land cards yet.</p>
    <% else %>
      <% max_count = @mana_curve.values.max %>
      <div class="space-y-2">
        <% @mana_curve.sort_by { |cmc, _| cmc.to_f }.each do |cmc, count| %>
          <div class="flex items-center gap-3">
            <span class="text-slate-400 text-xs w-6 text-right"><%= cmc %></span>
            <div class="flex-1 bg-slate-700 rounded-full h-4 overflow-hidden">
              <div class="bg-blue-500 h-4 rounded-full" style="width: <%= (count.to_f / max_count * 100).round %>%"></div>
            </div>
            <span class="text-slate-300 text-xs w-6"><%= count %></span>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# Category breakdown %>
  <div class="bg-slate-800 border border-slate-700 rounded-xl p-5">
    <h2 class="text-white font-semibold mb-4">Category Breakdown</h2>
    <% if @cards_by_category.empty? %>
      <p class="text-slate-400 text-sm">No cards yet.</p>
    <% else %>
      <div class="space-y-2">
        <% total = @deck.card_count.to_f %>
        <% @cards_by_category.each do |category, cards| %>
          <% count = cards.sum(&:quantity) %>
          <div class="flex items-center gap-3">
            <span class="text-slate-400 text-xs w-24 capitalize"><%= category %></span>
            <div class="flex-1 bg-slate-700 rounded-full h-4 overflow-hidden">
              <div class="bg-blue-500 h-4 rounded-full" style="width: <%= total > 0 ? (count / total * 100).round : 0 %>%"></div>
            </div>
            <span class="text-slate-300 text-xs w-6"><%= count %></span>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<%# Upgrade suggestions %>
<% if @upgrades.any? %>
  <div class="mt-6 bg-slate-800 border border-slate-700 rounded-xl p-5">
    <h2 class="text-white font-semibold mb-4">Upgrade Suggestions</h2>
    <p class="text-slate-400 text-sm mb-4">These cards in your deck have a clearly stronger replacement available.</p>
    <div class="space-y-6">
      <% @upgrades.each do |upgrade| %>
        <div class="border border-slate-700 rounded-lg p-4">
          <%# Card pair — centered, fixed-width cards %>
          <div class="flex items-start justify-center gap-4 mb-4">
            <%# Current card %>
            <% sid = upgrade[:current_card].scryfall_id %>
            <% current_img = sid.present? ? "https://cards.scryfall.io/normal/front/#{sid[0]}/#{sid[1]}/#{sid}.jpg" : nil %>
            <div class="flex flex-col items-center text-center w-[160px] shrink-0">
              <% if current_img %>
                <img src="<%= current_img %>" alt="<%= upgrade[:current_card].card_name %>"
                     class="w-full rounded-lg object-contain border border-slate-600 mb-2">
              <% else %>
                <div class="w-full aspect-[2/3] rounded-lg bg-slate-700 border border-slate-600 mb-2"></div>
              <% end %>
              <p class="text-slate-400 text-xs mb-0.5">Currently in deck</p>
              <p class="text-white font-medium text-sm leading-tight"><%= upgrade[:current_card].card_name %></p>
              <p class="text-slate-500 text-xs capitalize mt-0.5"><%= upgrade[:current_card].category %> · CMC <%= upgrade[:current_card].cmc.to_i %></p>
            </div>

            <%# Arrow %>
            <div class="flex items-center justify-center pt-16 shrink-0">
              <span class="text-slate-500 text-2xl">→</span>
            </div>

            <%# Upgrade card %>
            <% upgrade_img = upgrade[:upgrade_card].dig("image_uris", "normal") || upgrade[:upgrade_card].dig("card_faces", 0, "image_uris", "normal") %>
            <div class="flex flex-col items-center text-center w-[160px] shrink-0">
              <% if upgrade_img %>
                <img src="<%= upgrade_img %>" alt="<%= upgrade[:upgrade_card]["name"] %>"
                     class="w-full rounded-lg object-contain border border-slate-600 mb-2">
              <% else %>
                <div class="w-full aspect-[2/3] rounded-lg bg-slate-700 border border-slate-600 mb-2"></div>
              <% end %>
              <p class="text-green-400 text-xs mb-0.5">Suggested upgrade</p>
              <p class="text-white font-medium text-sm leading-tight"><%= upgrade[:upgrade_card]["name"] %></p>
              <p class="text-slate-500 text-xs mt-0.5">CMC <%= upgrade[:upgrade_card]["cmc"].to_i %></p>
            </div>
          </div>

          <%# Reason, oracle text, and Add button %>
          <p class="text-slate-400 text-xs italic mb-2"><%= upgrade[:reason] %></p>
          <% oracle = upgrade[:upgrade_card]["oracle_text"].to_s.truncate(150) %>
          <% if oracle.present? %>
            <p class="text-slate-500 text-xs leading-relaxed mb-3"><%= oracle %></p>
          <% end %>
          <div class="flex justify-end">
            <%= form_with url: deck_deck_cards_path(@deck), method: :post do |f| %>
              <%= f.hidden_field :scryfall_id, value: upgrade[:upgrade_card]["id"] %>
              <%= f.hidden_field :card_name,   value: upgrade[:upgrade_card]["name"] %>
              <%= f.submit "Add Upgrade", name: nil,
                  class: "bg-green-700 hover:bg-green-600 text-white text-xs font-medium px-3 py-1.5 rounded-md cursor-pointer transition-colors whitespace-nowrap" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<%# Combos section %>
<div class="mt-6 bg-slate-800 border border-slate-700 rounded-xl p-5">
  <h2 class="text-white font-semibold mb-4">Combo Potential <span class="text-slate-500 text-xs font-normal ml-1">via Commander Spellbook</span></h2>

  <% if @combos.empty? %>
    <div class="text-center py-8 border border-dashed border-slate-600 rounded-xl">
      <p class="text-slate-400 text-sm">No combos detected for this commander.</p>
      <a href="https://commanderspellbook.com" target="_blank" rel="noopener noreferrer"
         class="text-blue-400 hover:text-blue-300 text-xs mt-2 inline-block">
        Browse all combos on Commander Spellbook →
      </a>
    </div>
  <% else %>
    <div class="space-y-4">
      <% @combos.each_with_index do |combo, i| %>
        <div class="border border-slate-700 rounded-lg p-4">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1 min-w-0">
              <%# Cards involved %>
              <div class="flex flex-wrap gap-1.5 mb-2">
                <% combo[:cards].each do |card_name| %>
                  <span class="bg-slate-700 text-slate-200 text-xs px-2 py-0.5 rounded-full font-medium"><%= card_name %></span>
                <% end %>
              </div>

              <%# Result %>
              <% if combo[:result].present? %>
                <p class="text-green-400 text-sm font-medium mb-1">⚡ <%= combo[:result] %></p>
              <% end %>

              <%# Steps %>
              <% if combo[:steps].present? %>
                <p class="text-slate-400 text-xs leading-relaxed line-clamp-3"><%= combo[:steps] %></p>
              <% end %>
            </div>

            <a href="https://commanderspellbook.com/search/?q=card%3A<%= ERB::Util.url_encode(combo[:cards].first.to_s) %>"
               target="_blank" rel="noopener noreferrer"
               class="shrink-0 text-blue-400 hover:text-blue-300 text-xs whitespace-nowrap">
              View →
            </a>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
