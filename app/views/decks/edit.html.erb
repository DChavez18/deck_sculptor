<h1 class="text-3xl font-bold text-white mb-8">Edit Deck</h1>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
  <%# Commander — read-only %>
  <div>
    <h2 class="text-lg font-semibold text-slate-300 mb-4">Commander</h2>
    <div class="space-y-3">
      <% if @deck.commander.image_url.present? %>
        <a href="<%= commander_path(@deck.commander) %>">
          <img src="<%= @deck.commander.image_url %>" alt="<%= @deck.commander.name %>"
               class="rounded-xl shadow-2xl shadow-blue-900/30 border border-slate-700 w-full max-w-xs">
        </a>
      <% end %>
      <div>
        <p class="text-white font-semibold"><%= @deck.commander.name %></p>
        <p class="text-slate-400 text-xs"><%= @deck.commander.type_line %></p>
      </div>
      <p class="text-slate-500 text-xs">Commander cannot be changed after deck creation.</p>
    </div>
  </div>

  <%# Deck form %>
  <div>
    <h2 class="text-lg font-semibold text-slate-300 mb-4">Deck Details</h2>

    <%= form_with model: @deck, class: "space-y-4" do |f| %>
      <% if @deck.errors.any? %>
        <div class="bg-red-900 border border-red-700 text-red-200 px-4 py-3 rounded-md text-sm">
          <ul class="list-disc list-inside space-y-1">
            <% @deck.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :name, "Deck Name", class: "block text-sm text-slate-400 mb-1" %>
        <%= f.text_field :name,
            class: "w-full bg-slate-700 border border-slate-600 text-white placeholder-slate-400 rounded-md px-4 py-3 focus:outline-none focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :archetype, "Archetype", class: "block text-sm text-slate-400 mb-1" %>
        <%= f.select :archetype,
            Deck::ARCHETYPES.map { |a| [a.capitalize, a] },
            { include_blank: "— Select archetype —" },
            class: "w-full bg-slate-700 border border-slate-600 text-white rounded-md px-4 py-3 focus:outline-none focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :bracket_level, "Bracket Level (1–5)", class: "block text-sm text-slate-400 mb-1" %>
        <%= f.number_field :bracket_level, min: 1, max: 5,
            class: "w-full bg-slate-700 border border-slate-600 text-white rounded-md px-4 py-3 focus:outline-none focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :description, "Description (optional)", class: "block text-sm text-slate-400 mb-1" %>
        <%= f.text_area :description, rows: 3,
            class: "w-full bg-slate-700 border border-slate-600 text-white placeholder-slate-400 rounded-md px-4 py-3 focus:outline-none focus:border-blue-500 resize-none" %>
      </div>

      <div class="pt-2 flex gap-3">
        <%= f.submit "Save Changes", class: "bg-blue-600 hover:bg-blue-500 text-white font-semibold px-6 py-3 rounded-md cursor-pointer transition-colors" %>
        <%= link_to "Cancel", deck_path(@deck), class: "text-slate-400 hover:text-white py-3 px-2 text-sm" %>
      </div>
    <% end %>
  </div>
</div>
