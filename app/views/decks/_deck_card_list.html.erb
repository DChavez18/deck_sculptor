<% if cards_by_category.empty? %>
  <div class="text-center py-16 border border-dashed border-slate-600 rounded-xl">
    <p class="text-slate-400">No cards added yet.</p>
    <p class="text-slate-500 text-sm mt-1">Use the form above to add cards to your deck.</p>
  </div>
<% else %>
  <div data-controller="deck-sort">
    <div class="flex justify-end gap-2 mb-3">
      <button data-deck-sort-target="nameButton"
              data-action="click->deck-sort#sortByName"
              class="bg-blue-600 text-white text-xs px-3 py-1 rounded-md font-medium transition-colors">
        A-Z
      </button>
      <button data-deck-sort-target="cmcButton"
              data-action="click->deck-sort#sortByCmc"
              class="bg-slate-700 text-slate-300 text-xs px-3 py-1 rounded-md font-medium transition-colors">
        CMC
      </button>
    </div>
    <div class="space-y-4">
    <% cards_by_category.each_with_index do |(category, cards), idx| %>
      <div class="bg-slate-800 border border-slate-700 rounded-xl overflow-hidden">
        <div class="px-5 py-3 bg-slate-750 border-b border-slate-700 flex items-center justify-between cursor-pointer select-none"
             onclick="(function(el){var body=el.closest('.bg-slate-800').querySelector('.category-body');var chevron=el.querySelector('.chevron');var collapsed=body.style.display==='none';body.style.display=collapsed?'':'none';chevron.style.transform=collapsed?'':'rotate(-90deg)'})(this)">
          <h3 class="text-white font-semibold capitalize"><%= category %></h3>
          <div class="flex items-center gap-3">
            <span class="text-slate-400 text-sm"><%= cards.sum(&:quantity) %></span>
            <span class="chevron text-slate-400 text-sm transition-transform duration-150">▾</span>
          </div>
        </div>
        <div class="category-body divide-y divide-slate-700">
          <% cards.each do |card| %>
            <div class="px-4 py-2 flex items-center justify-between"
                 data-card-name="<%= card.card_name %>"
                 data-card-cmc="<%= card.cmc || 0 %>">
              <div class="flex items-center gap-3">
                <% if card.image_uri.present? %>
                  <img src="<%= card.image_uri&.gsub('/normal/', '/small/') %>" alt="<%= card.card_name %>"
                       class="w-8 h-11 rounded object-cover shrink-0 border border-slate-600">
                <% else %>
                  <div class="w-8 h-11 rounded bg-slate-700 border border-slate-600 shrink-0"></div>
                <% end %>
                <div class="flex items-center gap-1 shrink-0">
                  <%= button_to deck_deck_card_path(deck, card), method: :patch,
                      params: { deck_card: { quantity: card.quantity - 1 } },
                      class: "bg-slate-700 hover:bg-slate-600 text-slate-300 hover:text-white w-5 h-5 rounded text-xs font-bold leading-none flex items-center justify-center" do %>−<% end %>
                  <span class="text-slate-300 text-sm w-5 text-center"><%= card.quantity %></span>
                  <%= button_to deck_deck_card_path(deck, card), method: :patch,
                      params: { deck_card: { quantity: card.quantity + 1 } },
                      disabled: !card.basic_land? && card.quantity >= 1,
                      class: "bg-slate-700 hover:bg-slate-600 text-slate-300 hover:text-white w-5 h-5 rounded text-xs font-bold leading-none flex items-center justify-center disabled:opacity-30 disabled:cursor-not-allowed" do %>+<% end %>
                </div>
                <span class="text-white text-sm"><%= card.card_name %></span>
                <% if card.mana_cost.present? %>
                  <span class="text-slate-500 text-xs font-mono"><%= card.mana_cost %></span>
                <% end %>
              </div>
              <%= button_to deck_deck_card_path(deck, card), method: :delete,
                  class: "text-slate-600 hover:text-red-400 text-xs transition-colors",
                  form: { data: { turbo_confirm: "Remove #{card.card_name}?" } } do %>
                ✕
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
    </div>
  </div>
<% end %>
