<div class="max-w-5xl mx-auto">
  <div class="mb-6">
    <%= link_to "← Back to #{@deck.name}", deck_path(@deck),
        class: "text-blue-400 hover:text-blue-300 text-sm transition-colors" %>
  </div>

  <div class="mb-6">
    <h1 class="text-2xl font-bold text-white">
      <%= @category_label %> (<%= @cards.sum(&:quantity) %>)
    </h1>
    <p class="text-slate-400 text-sm mt-1"><%= @deck.name %></p>
  </div>

  <% if @cards.empty? %>
    <div class="bg-slate-800 border border-slate-700 rounded-xl p-8 text-center">
      <p class="text-slate-400 mb-4">No <%= @category_label %> cards in this deck yet.</p>
      <%= link_to "Browse Suggestions", suggestions_deck_path(@deck),
          class: "bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium px-4 py-2 rounded-md transition-colors" %>
    </div>
  <% else %>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
      <% @cards.each do |deck_card| %>
        <% sid = deck_card.scryfall_id %>
        <div class="bg-slate-800 border border-slate-700 rounded-xl overflow-hidden flex flex-col">
          <% if sid.present? %>
            <img src="https://cards.scryfall.io/normal/front/<%= sid[0] %>/<%= sid[1] %>/<%= sid %>.jpg"
                 alt="<%= deck_card.card_name %>"
                 class="w-full object-cover"
                 loading="lazy">
          <% else %>
            <div class="w-full aspect-[5/7] bg-slate-700 flex items-center justify-center">
              <span class="text-slate-500 text-4xl">🎴</span>
            </div>
          <% end %>

          <div class="p-3 flex flex-col gap-2 flex-1">
            <p class="text-white text-sm font-medium leading-tight"><%= deck_card.card_name %></p>
            <div class="flex items-center justify-between">
              <span class="bg-slate-700 text-slate-300 text-xs px-2 py-0.5 rounded-full">
                CMC <%= deck_card.cmc.to_i %>
              </span>
              <%= button_to deck_deck_card_path(@deck, deck_card),
                  method: :delete,
                  data: { turbo_confirm: "Remove #{deck_card.card_name} from this deck?" },
                  class: "text-red-400 hover:text-red-300 text-xs transition-colors bg-transparent border-0 p-0 cursor-pointer" do %>
                Remove
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
