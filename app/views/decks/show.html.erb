<div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
  <%# Commander sidebar %>
  <div class="lg:col-span-1">
    <div class="bg-slate-800 border border-slate-700 rounded-xl overflow-hidden sticky top-6">
      <%= link_to commander_path(@deck.commander) do %>
        <% if @deck.commander.image_url.present? %>
          <img src="<%= @deck.commander.image_url %>" alt="<%= @deck.commander.name %>" class="w-full hover:opacity-90 transition-opacity">
        <% else %>
          <div class="h-48 bg-slate-700 flex items-center justify-center hover:bg-slate-600 transition-colors">
            <span class="text-slate-500 text-5xl">🎴</span>
          </div>
        <% end %>
      <% end %>

      <div class="p-4 space-y-2">
        <%= link_to @deck.commander.name, commander_path(@deck.commander),
            class: "text-white font-bold text-lg leading-tight hover:text-blue-400 transition-colors block" %>
        <p class="text-slate-400 text-xs"><%= @deck.commander.type_line %></p>
        <p class="text-slate-300 text-xs leading-relaxed"><%= @deck.commander.oracle_text %></p>

        <%# Color identity pips %>
        <% unless @deck.commander.color_identity_array.empty? %>
          <div class="flex flex-wrap gap-1 pt-1">
            <% color_pip_map = { "W" => { label: "W", bg: "bg-yellow-100",  text: "text-yellow-900" },
                                  "U" => { label: "U", bg: "bg-blue-500",    text: "text-white" },
                                  "B" => { label: "B", bg: "bg-slate-900",   text: "text-slate-100" },
                                  "R" => { label: "R", bg: "bg-red-600",     text: "text-white" },
                                  "G" => { label: "G", bg: "bg-green-600",   text: "text-white" } } %>
            <% @deck.commander.color_identity_array.each do |color| %>
              <% pip = color_pip_map[color] || { label: color, bg: "bg-slate-600", text: "text-white" } %>
              <span title="<%= @deck.commander.color_names.find { |n| Commander::COLOR_MAP[color] == n } %>"
                    class="<%= pip[:bg] %> <%= pip[:text] %> text-xs font-bold w-6 h-6 rounded-full flex items-center justify-center border border-slate-600">
                <%= pip[:label] %>
              </span>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# Main content %>
  <div class="lg:col-span-3 space-y-6">
    <%# Header %>
    <div class="flex items-start justify-between">
      <div>
        <h1 class="text-3xl font-bold text-white"><%= @deck.name %></h1>
        <p class="text-slate-400 text-sm mt-1 capitalize"><%= @deck.archetype %> · Bracket Level <%= @deck.bracket_level %></p>
        <% if @deck.description.present? %>
          <p class="text-slate-300 text-sm mt-2"><%= @deck.description %></p>
        <% end %>
      </div>
      <div class="flex flex-wrap gap-2 shrink-0">
        <%= link_to "Suggestions", suggestions_deck_path(@deck),
            class: "bg-blue-600 hover:bg-blue-500 text-white text-sm px-4 py-2 rounded-md font-medium" %>
        <%= link_to "Analysis", analysis_deck_path(@deck),
            class: "bg-slate-700 hover:bg-slate-600 text-white text-sm px-4 py-2 rounded-md font-medium" %>
        <%= link_to "Edit Deck", edit_deck_path(@deck),
            class: "bg-slate-700 hover:bg-slate-600 text-white text-sm px-4 py-2 rounded-md font-medium" %>
        <%= link_to "Export", export_deck_path(@deck),
            class: "bg-slate-700 hover:bg-slate-600 text-slate-300 text-sm font-medium px-4 py-2 rounded-md transition-colors" %>
      </div>
    </div>

    <div id="deck_stats">
      <%= render "deck_stats", deck: @deck %>
    </div>

    <%# Building Toward: ratio targets panel (only when intent is set) %>
    <% if @deck.intent_completed? %>
      <div class="bg-slate-800 border border-slate-700 rounded-xl p-5">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-white font-semibold text-sm">Building Toward</h3>
          <%= link_to "Full Analysis →", analysis_deck_path(@deck),
              class: "text-blue-400 hover:text-blue-300 text-xs" %>
        </div>
        <div class="space-y-3">
          <% [
            [:creature, "Creatures"],
            [:ramp,     "Ramp"],
            [:draw,     "Card Draw"],
            [:removal,  "Removal"],
            [:land,     "Lands"]
          ].each do |bucket, label| %>
            <% entry = @ratio_report[bucket] %>
            <% next unless entry %>
            <% pct = [(entry[:actual].to_f / entry[:target]) * 100, 100].min.round %>
            <%= link_to deck_cards_by_category_deck_path(@deck, bucket),
                class: "block hover:bg-slate-750 rounded-lg transition-colors -mx-1 px-1" do %>
              <div>
                <div class="flex justify-between text-xs mb-1">
                  <span class="text-slate-400"><%= label %></span>
                  <span class="<%= entry[:actual] >= entry[:target] ? 'text-green-400' : 'text-slate-400' %>">
                    <%= entry[:actual] %> / <%= entry[:target] %>
                  </span>
                </div>
                <div class="w-full bg-slate-700 rounded-full h-1.5">
                  <div class="<%= entry[:actual] >= entry[:target] ? 'bg-green-500' : 'bg-blue-500' %> h-1.5 rounded-full"
                       style="width: <%= pct %>%"></div>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Add card form with live search %>
    <div class="bg-slate-800 border border-slate-700 rounded-xl p-5"
         data-controller="card-search">
      <h3 class="text-white font-semibold mb-3">Add Card</h3>

      <%# Search input %>
      <div class="relative mb-3">
        <input type="text"
               placeholder="Search for a card..."
               autocomplete="off"
               data-card-search-target="input"
               data-action="input->card-search#search"
               class="w-full bg-slate-700 border border-slate-600 text-white placeholder-slate-400 rounded-md px-4 py-2 focus:outline-none focus:border-blue-500 text-sm">
        <div data-card-search-target="dropdown"
             class="hidden absolute z-10 w-full mt-1 bg-slate-800 border border-slate-600 rounded-lg shadow-xl max-h-72 overflow-y-auto divide-y divide-slate-700">
        </div>
      </div>

      <%# Selected card / error feedback %>
      <p data-card-search-target="selectedDisplay"
         class="hidden text-blue-400 text-sm mb-3"></p>
      <p data-card-search-target="error"
         class="hidden text-red-400 text-sm mb-3">Please select a card from the search results.</p>

      <%# Hidden form — submits scryfall_id + card_name %>
      <%= form_with url: deck_deck_cards_path(@deck), method: :post,
          data: { action: "submit->card-search#validateAndSubmit" } do |f| %>
        <input type="hidden" name="deck_card[scryfall_id]" data-card-search-target="scryfallId">
        <input type="hidden" name="deck_card[card_name]"   data-card-search-target="cardName">
        <%= f.submit "Add Card", class: "hidden" %>
      <% end %>
    </div>

    <%# Import Decklist panel %>
    <div class="bg-slate-800 border border-slate-700 rounded-xl overflow-hidden"
         data-controller="deck-import">

      <%# Toggle header %>
      <button type="button"
              data-action="click->deck-import#toggle"
              class="w-full flex items-center justify-between px-5 py-4 text-left hover:bg-slate-750 transition-colors">
        <div class="flex items-center gap-2">
          <span class="text-white font-semibold text-sm">Import Decklist</span>
          <span class="text-slate-500 text-xs">Paste a plain text decklist</span>
        </div>
        <span class="text-slate-400 text-xs" data-deck-import-target="toggleIcon">▼</span>
      </button>

      <%# Collapsible body — hidden by default %>
      <div class="hidden border-t border-slate-700 p-5" data-deck-import-target="panel">
        <%= form_with url: deck_deck_imports_path(@deck), method: :post,
                      data: { action: "submit->deck-import#submit turbo:submit-end->deck-import#submitEnd", turbo_stream: true } do |f| %>
          <textarea name="decklist"
                    rows="8"
                    placeholder="1 Sol Ring&#10;1x Arcane Signet&#10;1 Command Tower (CMR) 281&#10;..."
                    class="w-full bg-slate-700 border border-slate-600 text-white placeholder-slate-500 rounded-md px-4 py-3 text-sm font-mono focus:outline-none focus:border-blue-500 resize-y mb-3"></textarea>
          <div class="flex items-center gap-3">
            <%= f.submit "Import Cards",
                data: { deck_import_target: "submitButton" },
                class: "bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium px-4 py-2 rounded-md transition-colors cursor-pointer" %>
            <div id="import-result"></div>
          </div>
        <% end %>
      </div>
    </div>

    <%# Cards by category %>
    <div id="deck_card_list">
      <%= render "deck_card_list", deck: @deck, cards_by_category: @cards_by_category %>
    </div>

    <%# AI Advisor chat panel %>
    <div class="bg-slate-800 border border-slate-700 rounded-xl overflow-hidden"
         data-controller="ai-chat">

      <%# Toggle header %>
      <button type="button"
              data-action="click->ai-chat#toggle"
              class="w-full flex items-center justify-between px-5 py-4 text-left hover:bg-slate-750 transition-colors">
        <div class="flex items-center gap-2">
          <span class="text-blue-400 font-semibold text-sm">AI Deck Advisor</span>
          <span class="text-slate-500 text-xs">Powered by Claude</span>
        </div>
        <span class="text-slate-400 text-xs" data-ai-chat-target="toggleIcon">▼</span>
      </button>

      <%# Collapsible body — hidden by default %>
      <div class="hidden border-t border-slate-700" data-ai-chat-target="panel">
        <%# Chat history %>
        <div id="chat-history"
             data-ai-chat-target="history"
             class="h-72 overflow-y-auto px-4 py-4 space-y-1 scroll-smooth">
          <% @deck.deck_chats.order(:created_at).each do |chat| %>
            <%= render "deck_chats/message", chat: chat %>
          <% end %>
          <% if @deck.deck_chats.none? %>
            <p class="text-slate-500 text-xs text-center pt-8">
              Ask me anything about your deck — cuts, additions, strategy, synergies.
            </p>
          <% end %>
        </div>

        <%# Input %>
        <div class="px-4 pb-4">
          <%= render "deck_chats/input", deck: @deck %>
        </div>
      </div>
    </div>
  </div>
</div>
