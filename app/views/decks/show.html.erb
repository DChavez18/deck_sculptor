<div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
  <%# Commander sidebar %>
  <div class="lg:col-span-1">
    <div class="bg-slate-800 border border-slate-700 rounded-xl overflow-hidden sticky top-6">
      <% if @deck.commander.image_url.present? %>
        <img src="<%= @deck.commander.image_url %>" alt="<%= @deck.commander.name %>" class="w-full">
      <% else %>
        <div class="h-48 bg-slate-700 flex items-center justify-center">
          <span class="text-slate-500 text-5xl">🎴</span>
        </div>
      <% end %>

      <div class="p-4 space-y-2">
        <h2 class="text-white font-bold text-lg leading-tight"><%= @deck.commander.name %></h2>
        <p class="text-slate-400 text-xs"><%= @deck.commander.type_line %></p>
        <p class="text-slate-300 text-xs leading-relaxed"><%= @deck.commander.oracle_text %></p>

        <%# Color identity pips %>
        <% unless @deck.commander.color_identity_array.empty? %>
          <div class="flex flex-wrap gap-1 pt-1">
            <% color_pip_map = { "W" => { label: "W", bg: "bg-yellow-100",  text: "text-yellow-900" },
                                  "U" => { label: "U", bg: "bg-blue-500",    text: "text-white" },
                                  "B" => { label: "B", bg: "bg-slate-900",   text: "text-slate-100" },
                                  "R" => { label: "R", bg: "bg-red-600",     text: "text-white" },
                                  "G" => { label: "G", bg: "bg-green-600",   text: "text-white" } } %>
            <% @deck.commander.color_identity_array.each do |color| %>
              <% pip = color_pip_map[color] || { label: color, bg: "bg-slate-600", text: "text-white" } %>
              <span title="<%= @deck.commander.color_names.find { |n| Commander::COLOR_MAP[color] == n } %>"
                    class="<%= pip[:bg] %> <%= pip[:text] %> text-xs font-bold w-6 h-6 rounded-full flex items-center justify-center border border-slate-600">
                <%= pip[:label] %>
              </span>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# Main content %>
  <div class="lg:col-span-3 space-y-6">
    <%# Header %>
    <div class="flex items-start justify-between">
      <div>
        <h1 class="text-3xl font-bold text-white"><%= @deck.name %></h1>
        <p class="text-slate-400 text-sm mt-1 capitalize"><%= @deck.archetype %> · Bracket Level <%= @deck.bracket_level %></p>
        <% if @deck.description.present? %>
          <p class="text-slate-300 text-sm mt-2"><%= @deck.description %></p>
        <% end %>
      </div>
      <div class="flex gap-2 shrink-0">
        <%= link_to "Suggestions", suggestions_deck_path(@deck),
            class: "bg-blue-600 hover:bg-blue-500 text-white text-sm px-4 py-2 rounded-md font-medium" %>
        <%= link_to "Analysis", analysis_deck_path(@deck),
            class: "bg-slate-700 hover:bg-slate-600 text-white text-sm px-4 py-2 rounded-md font-medium" %>
      </div>
    </div>

    <%# Card count progress bar %>
    <div class="bg-slate-800 border border-slate-700 rounded-xl px-5 py-4">
      <div class="flex items-center justify-between mb-2">
        <span class="text-white font-semibold text-sm">Deck Progress</span>
        <span class="text-slate-400 text-sm"><%= @deck.card_count %> / 99 cards</span>
      </div>
      <div class="bg-slate-700 rounded-full h-3 overflow-hidden">
        <div class="<%= @deck.complete? ? "bg-green-500" : "bg-blue-500" %> h-3 rounded-full transition-all"
             style="width: <%= [ (@deck.card_count.to_f / 99 * 100).round, 100 ].min %>%"></div>
      </div>
      <% if @deck.complete? %>
        <p class="text-green-400 text-xs mt-1">Deck complete!</p>
      <% else %>
        <p class="text-slate-500 text-xs mt-1"><%= 99 - @deck.card_count %> cards remaining</p>
      <% end %>
    </div>

    <%# Quick stats %>
    <div class="bg-slate-800 border border-slate-700 rounded-xl px-5 py-4 grid grid-cols-3 gap-4 text-center">
      <div>
        <div class="text-2xl font-bold text-white"><%= @deck.land_count %></div>
        <div class="text-slate-400 text-xs mt-0.5">Lands</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-white"><%= @deck.avg_cmc %></div>
        <div class="text-slate-400 text-xs mt-0.5">Avg CMC</div>
      </div>
      <div>
        <% top_category = @cards_by_category.max_by { |_, cards| cards.sum(&:quantity) }&.first %>
        <div class="text-xl font-bold text-white capitalize"><%= top_category || "—" %></div>
        <div class="text-slate-400 text-xs mt-0.5">Top Category</div>
      </div>
    </div>

    <%# Add card form with live search %>
    <div class="bg-slate-800 border border-slate-700 rounded-xl p-5"
         data-controller="card-search">
      <h3 class="text-white font-semibold mb-3">Add Card</h3>

      <%# Search input %>
      <div class="relative mb-3">
        <input type="text"
               placeholder="Search for a card..."
               autocomplete="off"
               data-card-search-target="input"
               data-action="input->card-search#search"
               class="w-full bg-slate-700 border border-slate-600 text-white placeholder-slate-400 rounded-md px-4 py-2 focus:outline-none focus:border-blue-500 text-sm">
        <div data-card-search-target="dropdown"
             class="hidden absolute z-10 w-full mt-1 bg-slate-800 border border-slate-600 rounded-lg shadow-xl max-h-72 overflow-y-auto divide-y divide-slate-700">
        </div>
      </div>

      <%# Selected card / error feedback %>
      <p data-card-search-target="selectedDisplay"
         class="hidden text-blue-400 text-sm mb-3"></p>
      <p data-card-search-target="error"
         class="hidden text-red-400 text-sm mb-3">Please select a card from the search results.</p>

      <%# Hidden form — submits scryfall_id + card_name %>
      <%= form_with url: deck_deck_cards_path(@deck), method: :post, class: "flex justify-end",
          data: { action: "submit->card-search#validateAndSubmit" } do |f| %>
        <input type="hidden" name="deck_card[scryfall_id]" data-card-search-target="scryfallId">
        <input type="hidden" name="deck_card[card_name]"   data-card-search-target="cardName">
        <%= f.submit "Add Card", class: "bg-blue-600 hover:bg-blue-500 text-white text-sm px-5 py-2 rounded-md font-medium cursor-pointer" %>
      <% end %>
    </div>

    <%# Cards by category %>
    <% if @cards_by_category.empty? %>
      <div class="text-center py-16 border border-dashed border-slate-600 rounded-xl">
        <p class="text-slate-400">No cards added yet.</p>
        <p class="text-slate-500 text-sm mt-1">Use the form above to add cards to your deck.</p>
      </div>
    <% else %>
      <% @cards_by_category.each do |category, cards| %>
        <div class="bg-slate-800 border border-slate-700 rounded-xl overflow-hidden">
          <div class="px-5 py-3 bg-slate-750 border-b border-slate-700 flex items-center justify-between">
            <h3 class="text-white font-semibold capitalize"><%= category %></h3>
            <span class="text-slate-400 text-sm"><%= cards.sum(&:quantity) %></span>
          </div>
          <div class="divide-y divide-slate-700">
            <% cards.each do |card| %>
              <div class="px-5 py-3 flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <span class="text-slate-400 text-sm w-4 text-right"><%= card.quantity %>×</span>
                  <span class="text-white text-sm"><%= card.card_name %></span>
                  <% if card.mana_cost.present? %>
                    <span class="text-slate-500 text-xs font-mono"><%= card.mana_cost %></span>
                  <% end %>
                </div>
                <%= button_to deck_deck_card_path(@deck, card), method: :delete,
                    class: "text-slate-600 hover:text-red-400 text-xs transition-colors",
                    form: { data: { turbo_confirm: "Remove #{card.card_name}?" } } do %>
                  ✕
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
