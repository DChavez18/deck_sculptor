<div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
  <%# Commander sidebar %>
  <div class="lg:col-span-1">
    <div class="bg-slate-800 border border-slate-700 rounded-xl overflow-hidden sticky top-6">
      <% if @deck.commander.image_url.present? %>
        <img src="<%= @deck.commander.image_url %>" alt="<%= @deck.commander.name %>" class="w-full">
      <% else %>
        <div class="h-48 bg-slate-700 flex items-center justify-center">
          <span class="text-slate-500 text-5xl">🎴</span>
        </div>
      <% end %>

      <div class="p-4 space-y-2">
        <h2 class="text-white font-bold text-lg leading-tight"><%= @deck.commander.name %></h2>
        <p class="text-slate-400 text-xs"><%= @deck.commander.type_line %></p>
        <p class="text-slate-300 text-xs leading-relaxed"><%= @deck.commander.oracle_text %></p>

        <% unless @deck.commander.color_names.empty? %>
          <div class="flex flex-wrap gap-1 pt-1">
            <% @deck.commander.color_names.each do |color| %>
              <span class="text-xs bg-slate-700 text-slate-300 px-2 py-0.5 rounded-full"><%= color %></span>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# Main content %>
  <div class="lg:col-span-3 space-y-6">
    <%# Header %>
    <div class="flex items-start justify-between">
      <div>
        <h1 class="text-3xl font-bold text-white"><%= @deck.name %></h1>
        <p class="text-slate-400 text-sm mt-1 capitalize"><%= @deck.archetype %> · Power Level <%= @deck.power_level %></p>
        <% if @deck.description.present? %>
          <p class="text-slate-300 text-sm mt-2"><%= @deck.description %></p>
        <% end %>
      </div>
      <div class="flex gap-2 shrink-0">
        <%= link_to "Suggestions", suggestions_deck_path(@deck),
            class: "bg-blue-600 hover:bg-blue-500 text-white text-sm px-4 py-2 rounded-md font-medium" %>
        <%= link_to "Analysis", analysis_deck_path(@deck),
            class: "bg-slate-700 hover:bg-slate-600 text-white text-sm px-4 py-2 rounded-md font-medium" %>
      </div>
    </div>

    <%# Stats bar %>
    <div class="bg-slate-800 border border-slate-700 rounded-xl px-5 py-4 grid grid-cols-3 gap-4 text-center">
      <div>
        <div class="text-2xl font-bold text-white"><%= @deck.card_count %> <span class="text-slate-500 text-base font-normal">/ 99</span></div>
        <div class="text-slate-400 text-xs mt-0.5">Cards</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-white"><%= @deck.land_count %></div>
        <div class="text-slate-400 text-xs mt-0.5">Lands</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-white"><%= @deck.avg_cmc %></div>
        <div class="text-slate-400 text-xs mt-0.5">Avg CMC</div>
      </div>
    </div>

    <%# Add card form %>
    <div class="bg-slate-800 border border-slate-700 rounded-xl p-5">
      <h3 class="text-white font-semibold mb-4">Add Card</h3>
      <%= form_with url: deck_deck_cards_path(@deck), method: :post, class: "flex gap-3" do |f| %>
        <%= f.text_field :deck_card, placeholder: "Scryfall card name or ID...",
            name: "deck_card[card_name]",
            class: "flex-1 bg-slate-700 border border-slate-600 text-white placeholder-slate-400 rounded-md px-4 py-2 focus:outline-none focus:border-blue-500 text-sm" %>
        <%= f.hidden_field :deck_card, name: "deck_card[scryfall_id]", id: "deck_card_scryfall_id" %>
        <%= f.submit "Add", class: "bg-blue-600 hover:bg-blue-500 text-white text-sm px-5 py-2 rounded-md font-medium cursor-pointer" %>
      <% end %>
    </div>

    <%# Cards by category %>
    <% if @cards_by_category.empty? %>
      <div class="text-center py-16 border border-dashed border-slate-600 rounded-xl">
        <p class="text-slate-400">No cards added yet.</p>
        <p class="text-slate-500 text-sm mt-1">Use the form above to add cards to your deck.</p>
      </div>
    <% else %>
      <% @cards_by_category.each do |category, cards| %>
        <div class="bg-slate-800 border border-slate-700 rounded-xl overflow-hidden">
          <div class="px-5 py-3 bg-slate-750 border-b border-slate-700 flex items-center justify-between">
            <h3 class="text-white font-semibold capitalize"><%= category %></h3>
            <span class="text-slate-400 text-sm"><%= cards.sum(&:quantity) %></span>
          </div>
          <div class="divide-y divide-slate-700">
            <% cards.each do |card| %>
              <div class="px-5 py-3 flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <span class="text-slate-400 text-sm w-4 text-right"><%= card.quantity %>×</span>
                  <span class="text-white text-sm"><%= card.card_name %></span>
                  <% if card.mana_cost.present? %>
                    <span class="text-slate-500 text-xs font-mono"><%= card.mana_cost %></span>
                  <% end %>
                </div>
                <%= button_to deck_deck_card_path(@deck, card), method: :delete,
                    class: "text-slate-600 hover:text-red-400 text-xs transition-colors",
                    form: { data: { turbo_confirm: "Remove #{card.card_name}?" } } do %>
                  ✕
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
