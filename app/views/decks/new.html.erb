<h1 class="text-3xl font-bold text-white mb-8">New Deck</h1>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
  <%# Commander search %>
  <div>
    <h2 class="text-lg font-semibold text-slate-300 mb-4">Choose a Commander</h2>

    <div data-controller="commander-search">
      <%# Search input area — hidden when a commander is preselected %>
      <div data-commander-search-target="searchArea" class="<%= @preselected_commander ? 'hidden' : '' %>">
        <input
          type="text"
          placeholder="Search for a commander..."
          data-commander-search-target="input"
          data-action="input->commander-search#search"
          class="w-full bg-slate-700 border border-slate-600 text-white placeholder-slate-400 rounded-md px-4 py-3 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
        >

        <%= turbo_frame_tag "commander_results" do %>
          <p class="text-slate-500 text-sm mt-3">Type a name to search commanders.</p>
        <% end %>
      </div>

      <%# Commander preview — shown after selecting or when preselected %>
      <div data-commander-search-target="preview" class="<%= @preselected_commander ? '' : 'hidden' %>">
        <% if @preselected_commander %>
          <div class="space-y-3">
            <% if @preselected_commander.image_url.present? %>
              <a href="<%= commander_path(@preselected_commander) %>">
                <img src="<%= @preselected_commander.image_url %>" alt="<%= @preselected_commander.name %>"
                     class="rounded-xl shadow-2xl shadow-blue-900/30 border border-slate-700 w-full max-w-xs">
              </a>
            <% end %>
            <div>
              <p class="text-white font-semibold"><%= @preselected_commander.name %></p>
              <p class="text-slate-400 text-xs"><%= @preselected_commander.type_line %></p>
            </div>
            <button type="button" data-action="commander-search#clear"
              class="text-slate-400 hover:text-white text-sm underline underline-offset-2">
              Change commander
            </button>
          </div>
        <% end %>
      </div>

    </div>
  </div>

  <%# Deck form %>
  <div>
    <h2 class="text-lg font-semibold text-slate-300 mb-4">Deck Details</h2>

    <%= form_with model: @deck, class: "space-y-4" do |f| %>
      <input type="hidden" name="deck[commander_scryfall_id]" id="deck_commander_scryfall_id"
             value="<%= @preselected_commander&.scryfall_id %>">
      <% if @deck.errors.any? %>
        <div class="bg-red-900 border border-red-700 text-red-200 px-4 py-3 rounded-md text-sm">
          <ul class="list-disc list-inside space-y-1">
            <% @deck.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :name, "Deck Name", class: "block text-sm text-slate-400 mb-1" %>
        <%= f.text_field :name, placeholder: "e.g. The Mind Sculptor Control",
            class: "w-full bg-slate-700 border border-slate-600 text-white placeholder-slate-400 rounded-md px-4 py-3 focus:outline-none focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :archetype, "Archetype", class: "block text-sm text-slate-400 mb-1" %>
        <%= f.select :archetype,
            Deck::ARCHETYPES.map { |a| [a.capitalize, a] },
            { include_blank: "— Select archetype —" },
            class: "w-full bg-slate-700 border border-slate-600 text-white rounded-md px-4 py-3 focus:outline-none focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :bracket_level, "Bracket Level (1–5)", class: "block text-sm text-slate-400 mb-1" %>
        <%= f.number_field :bracket_level, min: 1, max: 5, value: 3,
            class: "w-full bg-slate-700 border border-slate-600 text-white rounded-md px-4 py-3 focus:outline-none focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :description, "Description (optional)", class: "block text-sm text-slate-400 mb-1" %>
        <%= f.text_area :description, rows: 3, placeholder: "Describe your deck strategy...",
            class: "w-full bg-slate-700 border border-slate-600 text-white placeholder-slate-400 rounded-md px-4 py-3 focus:outline-none focus:border-blue-500 resize-none" %>
      </div>

      <div class="pt-2">
        <%= f.submit "Create Deck", class: "w-full bg-blue-600 hover:bg-blue-500 text-white font-semibold py-3 rounded-md cursor-pointer transition-colors" %>
      </div>
    <% end %>
  </div>
</div>
