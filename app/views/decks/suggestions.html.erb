<div class="mb-6 flex items-center gap-4">
  <%= link_to "← Back to Deck", deck_path(@deck), class: "text-slate-400 hover:text-white text-sm" %>
  <h1 class="text-2xl font-bold text-white">Suggestions for <%= @deck.name %></h1>
</div>

<%# Intent summary panel %>
<div class="bg-slate-800 border border-slate-700 rounded-xl px-5 py-4 mb-5">
  <% if @deck.intent_completed? %>
    <div class="flex flex-wrap items-center gap-3">
      <span class="text-slate-400 text-xs font-medium uppercase tracking-wide">Deck Intent</span>

      <% if @deck.win_condition.present? %>
        <span class="bg-purple-800 text-purple-200 text-xs px-2.5 py-1 rounded-full">
          Win: <%= @deck.win_condition %>
        </span>
      <% end %>

      <% if @deck.archetype.present? %>
        <span class="bg-blue-800 text-blue-200 text-xs px-2.5 py-1 rounded-full capitalize">
          Playstyle: <%= @deck.archetype %>
        </span>
      <% end %>

      <% if @deck.budget.present? %>
        <% budget_labels = { "casual" => "Casual ($50)", "optimized" => "Optimized ($200)", "competitive" => "Competitive" } %>
        <span class="bg-green-800 text-green-200 text-xs px-2.5 py-1 rounded-full">
          Budget: <%= budget_labels.fetch(@deck.budget, @deck.budget.capitalize) %>
        </span>
      <% end %>

      <% if @deck.themes.present? %>
        <% @deck.themes.split(",").map(&:strip).first(3).each do |theme| %>
          <span class="bg-teal-800 text-teal-200 text-xs px-2.5 py-1 rounded-full"><%= theme %></span>
        <% end %>
      <% end %>

      <span class="ml-auto">
        <%= link_to "Edit Deck", edit_deck_path(@deck),
            class: "text-slate-400 hover:text-white text-xs underline underline-offset-2" %>
      </span>
    </div>
  <% else %>
    <div class="flex items-center justify-between">
      <p class="text-slate-400 text-sm">
        Add your deck intent to get better suggestions →
      </p>
      <%= link_to "Set Deck Intent", intent_deck_path(@deck),
          class: "bg-blue-600 hover:bg-blue-500 text-white text-xs font-medium px-3 py-1.5 rounded-md transition-colors" %>
    </div>
  <% end %>
</div>

<% if @edhrec_top.any? %>
  <div class="bg-slate-800 border border-slate-700 rounded-xl p-5 mb-6">
    <h2 class="text-white font-semibold mb-3">Popular with this Commander <span class="text-slate-500 text-xs font-normal ml-1">via EDHREC</span></h2>
    <div class="flex flex-wrap gap-2">
      <% @edhrec_top.each do |card_name| %>
        <span class="bg-slate-700 text-slate-300 text-xs px-2 py-1 rounded-full"><%= card_name %></span>
      <% end %>
    </div>
  </div>
<% end %>

<% if @suggestions.empty? %>
  <div class="text-center py-16 border border-dashed border-slate-600 rounded-xl">
    <p class="text-slate-400">No suggestions found.</p>
    <p class="text-slate-500 text-sm mt-1">Try adding more cards to your deck first.</p>
  </div>
<% else %>
  <div data-controller="suggestion-filter">
    <%# Filter bar %>
    <div class="flex flex-wrap items-center gap-2 mb-4">
      <% [
        ["all",     "All"],
        ["draw",    "Card Draw"],
        ["ramp",    "Ramp"],
        ["removal", "Removal"],
        ["board_wipe", "Board Wipes"],
        ["land",    "Lands"],
        ["combo",   "Combos"]
      ].each_with_index do |(value, label), i| %>
        <button type="button"
                data-suggestion-filter-target="pill"
                data-filter="<%= value %>"
                data-action="click->suggestion-filter#filter"
                class="<%= i == 0 ? 'bg-blue-600 text-white' : 'bg-slate-700 text-slate-300' %> text-xs font-medium px-3 py-1.5 rounded-full hover:bg-blue-500 hover:text-white transition-colors">
          <%= label %>
        </button>
      <% end %>

      <input type="text"
             data-suggestion-filter-target="search"
             data-action="input->suggestion-filter#search"
             placeholder="Search by name…"
             class="w-full sm:w-48 sm:ml-auto bg-slate-800 border border-slate-600 text-slate-300 text-xs placeholder-slate-500 rounded-lg px-3 py-1.5 focus:outline-none focus:border-blue-500">
    </div>

    <%# Card grid %>
    <div id="suggestions-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 items-start">
      <% @displayed_suggestions.each do |suggestion| %>
        <%= render "decks/suggestion_card", suggestion: suggestion, deck: @deck, feedbacks: @feedbacks %>
      <% end %>
    </div>

    <% if @suggestions.size > 30 %>
      <%= render "decks/load_more_button", deck: @deck, next_page: 2 %>
    <% end %>
  </div>
<% end %>
