<div class="mb-6 flex items-center gap-4">
  <%= link_to "← Back to Deck", deck_path(@deck), class: "text-slate-400 hover:text-white text-sm" %>
  <h1 class="text-2xl font-bold text-white">Suggestions for <%= @deck.name %></h1>
</div>

<% if @edhrec_top.any? %>
  <div class="bg-slate-800 border border-slate-700 rounded-xl p-5 mb-6">
    <h2 class="text-white font-semibold mb-3">Popular with this Commander <span class="text-slate-500 text-xs font-normal ml-1">via EDHREC</span></h2>
    <div class="flex flex-wrap gap-2">
      <% @edhrec_top.each do |card_name| %>
        <span class="bg-slate-700 text-slate-300 text-xs px-2 py-1 rounded-full"><%= card_name %></span>
      <% end %>
    </div>
  </div>
<% end %>

<% if @suggestions.empty? %>
  <div class="text-center py-16 border border-dashed border-slate-600 rounded-xl">
    <p class="text-slate-400">No suggestions found.</p>
    <p class="text-slate-500 text-sm mt-1">Try adding more cards to your deck first.</p>
  </div>
<% else %>
  <div data-controller="suggestion-filter">
    <%# Filter bar — Fix 3 %>
    <div class="flex flex-wrap items-center gap-2 mb-4">
      <% [
        ["all",     "All"],
        ["draw",    "Card Draw"],
        ["ramp",    "Ramp"],
        ["removal", "Removal"],
        ["wipe",    "Board Wipes"],
        ["land",    "Lands"],
        ["combo",   "Combos"]
      ].each_with_index do |(value, label), i| %>
        <button type="button"
                data-suggestion-filter-target="pill"
                data-filter="<%= value %>"
                data-action="click->suggestion-filter#filter"
                class="<%= i == 0 ? 'bg-blue-600 text-white' : 'bg-slate-700 text-slate-300' %> text-xs font-medium px-3 py-1.5 rounded-full hover:bg-blue-500 hover:text-white transition-colors">
          <%= label %>
        </button>
      <% end %>

      <input type="text"
             data-suggestion-filter-target="search"
             data-action="input->suggestion-filter#search"
             placeholder="Search by name…"
             class="ml-auto bg-slate-800 border border-slate-600 text-slate-300 text-xs placeholder-slate-500 rounded-lg px-3 py-1.5 focus:outline-none focus:border-blue-500 w-48">
    </div>

    <%# Card grid %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <% @suggestions.each do |suggestion| %>
        <% card = suggestion[:card] %>
        <div data-suggestion-filter-target="card"
             data-card-name="<%= card["name"] %>"
             data-filter-tags="<%= filter_tags_for(card, suggestion[:reasons]) %>"
             class="bg-slate-800 border border-slate-700 rounded-xl overflow-hidden flex flex-col">
          <% image_url = card.dig("image_uris", "normal") || card.dig("card_faces", 0, "image_uris", "normal") %>
          <% if image_url.present? %>
            <img src="<%= image_url %>" alt="<%= card["name"] %>" class="w-full h-40 object-cover object-top">
          <% end %>

          <div class="p-4 flex flex-col flex-1">
            <%# Score and reason badges %>
            <div class="flex flex-wrap gap-1.5 mb-3">
              <span class="bg-blue-600 text-white text-xs font-bold px-2 py-0.5 rounded-full">Score: <%= suggestion[:score] %></span>
              <% suggestion[:reasons].each do |reason| %>
                <span class="bg-slate-700 text-slate-300 text-xs px-2 py-0.5 rounded-full"><%= reason %></span>
              <% end %>
            </div>

            <h3 class="text-white font-semibold text-sm"><%= card["name"] %></h3>
            <p class="text-slate-400 text-xs mt-0.5"><%= card["type_line"] %></p>
            <% if card["mana_cost"].present? %>
              <p class="text-slate-500 text-xs font-mono mt-1"><%= card["mana_cost"] %></p>
            <% end %>

            <%# Oracle text with expand/collapse toggle — Fix 1 %>
            <div data-controller="card-text" class="flex-1">
              <p data-card-text-target="text" class="text-slate-300 text-xs mt-2 leading-relaxed line-clamp-3"><%= card["oracle_text"] %></p>
              <% if card["oracle_text"].to_s.length > 200 %>
                <button type="button"
                        data-card-text-target="expand"
                        data-action="card-text#expand"
                        class="text-blue-400 hover:text-blue-300 text-xs mt-1">Show more ↓</button>
                <button type="button"
                        data-card-text-target="collapse"
                        data-action="card-text#collapse"
                        class="text-blue-400 hover:text-blue-300 text-xs mt-1 hidden">Show less ↑</button>
              <% end %>
            </div>

            <%# Add to Deck button %>
            <div class="mt-3">
              <%= form_with url: deck_deck_cards_path(@deck), method: :post do |f| %>
                <%= f.hidden_field :deck_card, name: "deck_card[scryfall_id]", value: card["id"] %>
                <%= f.hidden_field :deck_card, name: "deck_card[card_name]",   value: card["name"] %>
                <%= f.submit "Add to Deck",
                    class: "w-full bg-blue-600 hover:bg-blue-500 text-white text-xs font-medium px-3 py-1.5 rounded-md cursor-pointer transition-colors" %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
