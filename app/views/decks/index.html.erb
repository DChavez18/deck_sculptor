<div class="flex items-center justify-between mb-8">
  <h1 class="text-3xl font-bold text-white">My Decks</h1>
  <%= link_to "New Deck", new_deck_path, class: "bg-blue-600 hover:bg-blue-500 text-white px-5 py-2 rounded-md font-medium" %>
</div>

<% if @decks.empty? %>
  <div class="text-center py-24 border border-dashed border-slate-600 rounded-xl">
    <p class="text-slate-400 text-lg mb-2">No decks yet.</p>
    <p class="text-slate-500 text-sm mb-6">Build your first Commander deck to get started.</p>
    <%= link_to "Create a Deck", new_deck_path, class: "bg-blue-600 hover:bg-blue-500 text-white px-6 py-3 rounded-md font-medium" %>
  </div>
<% else %>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    <% @decks.each do |deck| %>
      <%= link_to deck_path(deck), class: "bg-slate-800 border border-slate-700 rounded-xl overflow-hidden hover:border-blue-500 transition-colors block" do %>
        <div class="h-40 bg-slate-700 flex items-center justify-center overflow-hidden">
          <% if deck.commander.image_url.present? %>
            <img src="<%= deck.commander.image_url %>" alt="<%= deck.commander.name %>" class="w-full h-full object-cover object-top">
          <% else %>
            <span class="text-slate-500 text-4xl">🎴</span>
          <% end %>
        </div>
        <div class="p-4">
          <h2 class="text-white font-semibold text-lg truncate"><%= deck.name %></h2>
          <p class="text-slate-400 text-sm truncate"><%= deck.commander.name %></p>
          <div class="mt-3 flex items-center gap-3 text-xs text-slate-500">
            <span><%= deck.card_count %> / 99 cards</span>
            <span class="capitalize"><%= deck.archetype %></span>
            <span>Power <%= deck.power_level %></span>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>
