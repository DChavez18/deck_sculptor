<div class="flex items-center justify-between mb-8">
  <h1 class="text-3xl font-bold text-white">My Decks</h1>
  <%= link_to "New Deck", new_deck_path, class: "bg-blue-600 hover:bg-blue-500 text-white px-5 py-2 rounded-md font-medium" %>
</div>

<% if @decks.empty? %>
  <div class="text-center py-24 border border-dashed border-slate-600 rounded-xl">
    <p class="text-slate-400 text-lg mb-2">No decks yet.</p>
    <p class="text-slate-500 text-sm mb-6">Build your first Commander deck to get started.</p>
    <%= link_to "Create a Deck", new_deck_path, class: "bg-blue-600 hover:bg-blue-500 text-white px-6 py-3 rounded-md font-medium" %>
  </div>
<% else %>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    <% @decks.each do |deck| %>
      <div class="group relative bg-slate-800 border border-slate-700 rounded-xl overflow-hidden hover:border-blue-500 transition-colors">
        <%= link_to deck_path(deck), class: "block" do %>
          <div class="h-40 bg-slate-700 flex items-center justify-center overflow-hidden">
            <% if deck.commander.image_url.present? %>
              <img src="<%= deck.commander.image_url %>" alt="<%= deck.commander.name %>" class="w-full h-full object-cover object-top">
            <% else %>
              <span class="text-slate-500 text-4xl">🎴</span>
            <% end %>
          </div>
          <div class="p-4">
            <h2 class="text-white font-semibold text-lg truncate"><%= deck.name %></h2>
            <p class="text-slate-400 text-sm truncate"><%= deck.commander.name %></p>
            <div class="mt-3 flex items-center gap-3 text-xs text-slate-500">
              <span><%= deck.card_count %> / 99 cards</span>
              <span class="capitalize"><%= deck.archetype %></span>
              <span>Bracket <%= deck.bracket_level %></span>
            </div>
          </div>
        <% end %>

        <%# Edit/Delete icons — visible on hover %>
        <div class="absolute top-2 right-2 flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
          <%= link_to edit_deck_path(deck),
              class: "bg-slate-900/80 hover:bg-slate-700 text-white rounded-md p-1.5",
              title: "Edit deck" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536M9 13l6.586-6.586a2 2 0 112.828 2.828L11.828 15.828A2 2 0 0110 16.414V18h1.586a2 2 0 001.414-.586l6.586-6.586" />
            </svg>
          <% end %>
          <%= button_to deck_path(deck), method: :delete,
              data: { turbo_confirm: "Delete #{deck.name}? This cannot be undone." },
              class: "bg-slate-900/80 hover:bg-red-600 text-white rounded-md p-1.5",
              title: "Delete deck",
              form: { style: "display:inline" } do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M9 7V4h6v3M4 7h16" />
            </svg>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
