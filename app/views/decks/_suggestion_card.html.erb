<%# locals: suggestion (hash: card/score/reasons/pool), deck, feedbacks (hash scryfall_id => SuggestionFeedback) %>
<% pool_colors = {
  "Ramp"               => "bg-green-700 text-green-100",
  "Card Draw"          => "bg-blue-700 text-blue-100",
  "Removal"            => "bg-red-700 text-red-100",
  "Board Wipes"        => "bg-orange-700 text-orange-100",
  "Win Condition"      => "bg-purple-700 text-purple-100",
  "Combo"              => "bg-yellow-700 text-yellow-100",
  "Theme"              => "bg-teal-700 text-teal-100",
  "Commander Synergy"  => "bg-slate-600 text-slate-200",
  "Staple"             => "bg-gray-600 text-gray-200"
} %>
<% card        = suggestion[:card] %>
<% image_url   = card.dig("image_uris", "normal") || card.dig("card_faces", 0, "image_uris", "normal") %>
<% flippable   = image_url.present? %>
<% fb          = feedbacks[card["id"]] %>
<% thumbed_up  = fb&.feedback == "up" %>
<% thumbed_down = fb&.feedback == "down" %>

<%# Back-face content shared by flip and no-image variants %>
<% back_content = capture do %>
  <div class="p-4 flex flex-col h-full">
    <%# Score + pool + reason badges %>
    <div class="flex flex-wrap gap-1 mb-2 shrink-0">
      <span class="bg-blue-600 text-white text-xs font-bold px-2 py-0.5 rounded-full">Score: <%= suggestion[:score] %></span>
      <% if suggestion[:pool].present? %>
        <% pool_css = pool_colors.fetch(suggestion[:pool], "bg-slate-600 text-slate-200") %>
        <span class="<%= pool_css %> text-xs font-medium px-2 py-0.5 rounded-full"><%= suggestion[:pool] %></span>
      <% end %>
      <% suggestion[:reasons].each do |reason| %>
        <span class="bg-slate-700 text-slate-300 text-xs px-2 py-0.5 rounded-full"><%= reason %></span>
      <% end %>
    </div>

    <%# Card name, type, mana cost %>
    <h3 class="text-white font-semibold text-sm"><%= card["name"] %></h3>
    <p class="text-slate-400 text-xs mt-0.5"><%= card["type_line"] %></p>
    <% if card["mana_cost"].present? %>
      <p class="text-slate-500 text-xs font-mono mt-1"><%= card["mana_cost"] %></p>
    <% end %>

    <%# Oracle text with show more/less %>
    <div data-controller="card-text" class="flex-1 min-h-0 mt-2 overflow-y-auto">
      <p data-card-text-target="text" class="text-slate-300 text-xs leading-relaxed line-clamp-3"><%= card["oracle_text"] %></p>
      <% if card["oracle_text"].to_s.length > 200 %>
        <button type="button"
                data-card-text-target="expand"
                data-action="click->card-text#expand click->card-flip#stopPropagation"
                class="text-blue-400 hover:text-blue-300 text-xs mt-1">Show more ↓</button>
        <button type="button"
                data-card-text-target="collapse"
                data-action="click->card-text#collapse click->card-flip#stopPropagation"
                class="text-blue-400 hover:text-blue-300 text-xs mt-1 hidden">Show less ↑</button>
      <% end %>
    </div>

    <%# Add to Deck + thumbs buttons %>
    <div class="mt-3 shrink-0 flex flex-col gap-2" <%= flippable ? 'data-action="click->card-flip#stopPropagation"'.html_safe : "" %>>
      <%= form_with url: deck_deck_cards_path(deck), method: :post do |f| %>
        <%= hidden_field_tag "deck_card[scryfall_id]", card["id"] %>
        <%= hidden_field_tag "deck_card[card_name]",   card["name"] %>
        <%= hidden_field_tag "deck_card[return_to]",   "suggestions" %>
        <button type="submit"
                class="w-full bg-blue-600 hover:bg-blue-500 text-white text-xs font-medium px-3 py-1.5 rounded-md cursor-pointer transition-colors">
          Add to Deck
        </button>
      <% end %>

      <div class="flex gap-2" data-controller="thumb">
        <%= form_with url: deck_suggestion_feedbacks_path(deck), method: :post, class: "flex-1" do |f| %>
          <%= hidden_field_tag :scryfall_id, card["id"] %>
          <%= hidden_field_tag :card_name,   card["name"] %>
          <%= hidden_field_tag :feedback,    "up" %>
          <button type="submit"
                  data-thumb-target="up"
                  data-action="click->thumb#thumbUp"
                  class="w-full flex items-center justify-center gap-1 text-xs font-medium px-3 py-1.5 rounded-md cursor-pointer transition-colors <%= thumbed_up ? 'bg-green-600 text-white' : 'bg-slate-700 hover:bg-green-700 text-slate-300 hover:text-white' %>">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5">
              <path d="M7.493 18.75c-.425 0-.82-.236-.975-.632A7.48 7.48 0 016 15.375c0-1.75.599-3.358 1.602-4.634.151-.192.373-.309.6-.397.473-.183.89-.514 1.212-.924a9.042 9.042 0 012.861-2.4c.723-.384 1.35-.956 1.653-1.715a4.498 4.498 0 00.322-1.672V3a.75.75 0 01.75-.75 2.25 2.25 0 012.25 2.25c0 1.152-.26 2.243-.723 3.218-.266.558.107 1.282.725 1.282h3.126c1.026 0 1.945.694 2.054 1.715.045.422.068.85.068 1.285a11.95 11.95 0 01-2.649 7.521c-.388.482-.987.729-1.605.729H14.23c-.483 0-.964-.078-1.423-.23l-3.114-1.04a4.501 4.501 0 00-1.423-.23h-.777zM2.331 10.977a11.969 11.969 0 00-.831 4.398 12 12 0 00.52 3.507c.26.85 1.084 1.368 1.973 1.368H4.9c.445 0 .72-.498.523-.898a8.963 8.963 0 01-.924-3.977c0-1.708.476-3.305 1.302-4.666.245-.403-.028-.959-.5-.959H4.25c-.832 0-1.612.453-1.919 1.227z" />
            </svg>
          </button>
        <% end %>

        <%= form_with url: deck_suggestion_feedbacks_path(deck), method: :post, class: "flex-1" do |f| %>
          <%= hidden_field_tag :scryfall_id, card["id"] %>
          <%= hidden_field_tag :card_name,   card["name"] %>
          <%= hidden_field_tag :feedback,    "down" %>
          <button type="submit"
                  data-thumb-target="down"
                  data-action="click->thumb#thumbDown"
                  class="w-full flex items-center justify-center gap-1 text-xs font-medium px-3 py-1.5 rounded-md cursor-pointer transition-colors <%= thumbed_down ? 'bg-red-600 text-white' : 'bg-slate-700 hover:bg-red-700 text-slate-300 hover:text-white' %>">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5">
              <path d="M15.73 5.25h1.035A7.465 7.465 0 0118 9.375a7.465 7.465 0 01-1.235 4.125h-.148c-.806 0-1.534.446-2.031 1.08a9.04 9.04 0 01-2.861 2.4c-.723.384-1.35.956-1.653 1.715a4.498 4.498 0 00-.322 1.672V21a.75.75 0 01-.75.75 2.25 2.25 0 01-2.25-2.25c0-1.152.26-2.243.723-3.218C7.74 15.724 7.366 15 6.748 15H3.622c-1.026 0-1.945-.694-2.054-1.715A12.134 12.134 0 011.5 12c0-2.848.992-5.464 2.649-7.521.388-.482.987-.729 1.605-.729H9.77a4.5 4.5 0 011.423.23l3.114 1.04a4.5 4.5 0 001.423.23zM21.669 13.773c.536-1.362.831-2.845.831-4.398 0-1.22-.182-2.398-.52-3.507-.26-.85-1.084-1.368-1.973-1.368H19.1c-.445 0-.72.498-.523.898.591 1.2.924 2.55.924 3.977a8.959 8.959 0 01-1.302 4.666c-.245.403.028.959.5.959h1.053c.832 0 1.612-.453 1.919-1.227z" />
            </svg>
          </button>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<%# Outer filter + ID wrapper %>
<% suggested_category = CardCategorizer.new(card).category %>
<% filter_tags = [suggestion[:pool].to_s.downcase, suggested_category].uniq.join(" ") %>
<div id="suggestion-<%= card["id"] %>"
     data-suggestion-filter-target="card"
     data-card-name="<%= card["name"] %>"
     data-filter-tags="<%= filter_tags %>">

  <% if flippable %>
    <div class="card-flip-wrapper cursor-pointer"
         data-controller="card-flip"
         data-action="click->card-flip#flip">
      <div class="card-flip-inner" data-card-flip-target="inner">

        <%# Front face: full art — natural height drives the component size %>
        <div class="card-face bg-slate-900">
          <img src="<%= image_url %>" alt="<%= card["name"] %>" class="w-full h-auto">
        </div>

        <%# Back face: stats — absolute overlay matching front face dimensions %>
        <div class="card-face card-face-back bg-slate-800 border border-slate-700">
          <%= back_content %>
        </div>
      </div>
    </div>
  <% else %>
    <%# No image — just show the back face directly, no flip %>
    <div class="bg-slate-800 border border-slate-700 rounded-xl">
      <%= back_content %>
    </div>
  <% end %>
</div>
