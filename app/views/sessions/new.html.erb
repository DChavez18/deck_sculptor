<div class="max-w-md mx-auto mt-12">
  <div class="bg-slate-800 border border-slate-700 rounded-xl p-8">
    <h1 class="text-2xl font-bold text-white mb-8 text-center">Sign in to Deck Sculptor</h1>

    <%= render "shared/google_signin_button" %>

    <div class="my-6 flex items-center gap-4">
      <div class="flex-1 border-t border-slate-600"></div>
      <span class="text-slate-400 text-sm">or sign in with email</span>
      <div class="flex-1 border-t border-slate-600"></div>
    </div>

    <%= form_with url: session_path, method: :post do |form| %>
      <div class="mb-4">
        <%= form.label :email_address, "Email", class: "block text-sm font-medium text-slate-300 mb-1" %>
        <%= form.email_field :email_address,
            required: true,
            autofocus: true,
            autocomplete: "username",
            placeholder: "you@example.com",
            value: params[:email_address],
            class: "w-full bg-slate-700 border border-slate-600 text-white placeholder-slate-400 rounded-md px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
      </div>

      <div class="mb-6">
        <%= form.label :password, "Password", class: "block text-sm font-medium text-slate-300 mb-1" %>
        <div class="relative" data-controller="password-visibility">
          <%= form.password_field :password,
              required: true,
              autocomplete: "current-password",
              placeholder: "••••••••",
              maxlength: 72,
              data: { password_visibility_target: "input" },
              class: "w-full bg-slate-700 border border-slate-600 text-white placeholder-slate-400 rounded-md px-3 py-2.5 pr-12 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
          <button type="button"
                  data-action="click->password-visibility#toggle"
                  aria-label="Show or hide password"
                  class="absolute inset-y-0 right-0 flex items-center justify-center w-12 min-h-[44px] text-slate-400 hover:text-slate-200 transition-colors">
            <svg data-password-visibility-target="showIcon"
                 xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                 stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
            </svg>
            <svg data-password-visibility-target="hideIcon"
                 xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                 stroke-width="1.5" stroke="currentColor" class="w-5 h-5 hidden">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.451 10.451 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.522 10.522 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L9.88 9.88" />
            </svg>
          </button>
        </div>
      </div>

      <%= form.submit "Sign in",
          class: "w-full bg-blue-600 hover:bg-blue-500 text-white font-medium py-2.5 rounded-md cursor-pointer transition-colors min-h-[44px]" %>
    <% end %>

    <p class="mt-6 text-center text-sm text-slate-400">
      Don't have an account?
      <%= link_to "Sign up", signup_path, class: "text-blue-400 hover:text-blue-300 font-medium" %>
    </p>
  </div>
</div>
